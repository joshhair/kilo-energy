// Kilo Energy — Unified Database Schema
// SQLite via Prisma

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// USERS
// ============================================================================

/// Unified user table. Replaces separate Rep[] and hardcoded admin users.
model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  phone     String   @default("")

  /// "admin" | "rep" | "sub-dealer" | "project_manager"
  role      String   @default("rep")

  /// "closer" | "setter" | "both" — only meaningful when role = "rep".
  /// For non-rep roles (admin/sub-dealer/PM) defaults to "both" as a placeholder.
  /// Aligned to Turso schema (NOT NULL DEFAULT 'both') to prevent silent
  /// constraint failures — historical drift from agent cycle 861.
  repType   String   @default("both")

  active    Boolean  @default(true)

  /// Clerk user id, populated lazily on first sign-in by getInternalUser().
  /// Null for users created via silent bulk-import who have not yet accepted
  /// an invitation. Used for Clerk lifecycle ops (lock/unlock/delete) when
  /// deactivating or hard-deleting a user.
  clerkUserId String? @unique

  /// Whether this user can request blitzes for admin approval
  canRequestBlitz Boolean @default(false)
  /// Whether this user can create/manage blitzes directly
  canCreateBlitz  Boolean @default(false)

  /// PM-only: whether this project manager can export data
  canExport       Boolean @default(false)
  /// PM-only: whether this project manager can create new deals
  canCreateDeals  Boolean @default(false)
  /// PM-only: whether this project manager can access the Blitz module
  canAccessBlitz  Boolean @default(false)

  /// Vendor-PM scope: when set (and role = "project_manager"), this user
  /// is scoped to a single installer — they only see projects whose
  /// installerId matches this value, with commission/margin scrubbed.
  /// Intended for installer-side staff (e.g. BVI PM) who need to update
  /// project status/phase but shouldn't see sales compensation data.
  /// Null = full internal PM (all projects, full visibility).
  scopedInstallerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Relations ---
  projectsAsCloser   Project[]          @relation("ProjectCloser")
  projectsAsSetter   Project[]          @relation("ProjectSetter")
  projectsAsSubDealer Project[]         @relation("ProjectSubDealer")
  /// Deals where this user is the per-project trainer (one-off override).
  projectsAsTrainer   Project[]         @relation("ProjectTrainer")
  /// Deals where this user is a co-closer (not the primary closer). Used by
  /// the GDPR export to surface "deals I earned commission on" even when
  /// the user isn't the primary on the Project row.
  projectsAsAdditionalCloser ProjectCloser[] @relation("ProjectAdditionalClosers")
  projectsAsAdditionalSetter ProjectSetter[] @relation("ProjectAdditionalSetters")
  payrollEntries     PayrollEntry[]
  reimbursements     Reimbursement[]
  trainingAsTrainer  TrainerAssignment[] @relation("Trainer")
  trainingAsTrainee  TrainerAssignment[] @relation("Trainee")
  targetedIncentives Incentive[]
  blitzesCreated     Blitz[]            @relation("BlitzCreator")
  blitzesOwned       Blitz[]            @relation("BlitzOwner")
  blitzParticipations BlitzParticipant[]
  blitzRequests      BlitzRequest[]

  // BVI handoff back-relations
  projectFilesUploaded    ProjectFile[]
  projectSurveyLinksAdded ProjectSurveyLink[]
  projectInstallerNotes   ProjectInstallerNote[]
  emailDeliveriesCreated  EmailDelivery[]

  // Notification system back-relations
  notificationPreferences NotificationPreference[]
  notificationDeliveries  NotificationDelivery[]
  pushSubscriptions       PushSubscription[]

  // In-app feedback widget back-relation
  feedbackSubmitted       Feedback[]

  /// Optional E.164 phone number used for SMS notifications.
  /// Verified out-of-band (one-time code via Twilio); only populated
  /// after the user has confirmed ownership.
  notificationPhone        String?
  notificationPhoneVerifiedAt DateTime?

  /// User-controlled "do not send" window (server-enforced for SMS/push;
  /// email always immediate). Stored as ints 0–23 in UTC. Both null or
  /// equal → no quiet hours.
  quietHoursStartUtc Int?
  quietHoursEndUtc   Int?

  @@index([role])
  @@index([active])
  @@index([clerkUserId])
}

// ============================================================================
// INSTALLERS & FINANCERS
// ============================================================================

model Installer {
  id     String  @id @default(cuid())
  name   String  @unique
  active Boolean @default(true)

  /// 0-100. Percentage of M2 commission paid at Installed phase. Remainder paid at PTO (M3).
  installPayPct Int @default(80)

  /// Whether this installer uses product catalog pricing (per-product tiered, like SolarTech)
  usesProductCatalog Boolean @default(false)

  // --- Per-installer handoff config ---
  // Drives the auto-email of the BVI-style intake form on deal submission.
  // When handoffEnabled=false (default), no email fires regardless of other
  // fields — admin must explicitly enable per-installer after configuring
  // recipients. Edited via /api/installers/[id]/handoff-config; changes
  // logged via lib/audit.ts logChange against AUDITED_FIELDS.Installer.

  /// To: address for the handoff email. Null = handoff cannot fire.
  primaryEmail String?
  /// JSON-encoded String[] of CC addresses for the handoff email.
  ccEmails String @default("[]")
  /// Subject-line prefix, e.g. "[BVI]". Null = no prefix.
  subjectPrefix String?
  /// Master switch. False = collect data + render PDF on demand but never auto-send.
  handoffEnabled Boolean @default(false)
  /// Optional free-text appended to the handoff email body.
  customNotes String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects            Project[]
  pricingVersions     InstallerPricingVersion[]
  products            Product[]
  productCatalogConfig ProductCatalogConfig?
  prepaidOptions      InstallerPrepaidOption[]
  emailDeliveries     EmailDelivery[]

  @@index([active])
}

model InstallerPrepaidOption {
  id          String    @id @default(cuid())
  installerId String
  installer   Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  name        String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([installerId, name])
}

model Financer {
  id     String  @id @default(cuid())
  name   String  @unique
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

// ============================================================================
// PRICING — STANDARD INSTALLER TRACK
// ============================================================================

/// Versioned pricing for standard (non-product-catalog) installers.
/// Supports flat (single tier) and kW-tiered rates.
model InstallerPricingVersion {
  id            String    @id @default(cuid())
  installerId   String
  installer     Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  label         String
  effectiveFrom String    /// ISO date YYYY-MM-DD
  effectiveTo   String?   /// null = currently active

  /// "flat" | "tiered"
  rateType      String    @default("flat")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tiers    InstallerPricingTier[]
  projects Project[]              @relation("ProjectInstallerPricingVersion")

  @@index([installerId, effectiveFrom])
}

/// Rate tier within an InstallerPricingVersion.
/// Flat versions have 1 row (minKW=0, maxKW=null). Tiered have N rows.
model InstallerPricingTier {
  id         String                  @id @default(cuid())
  versionId  String
  version    InstallerPricingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  minKW      Float   @default(0)
  maxKW      Float?  /// null = no upper limit
  closerPerW Float
  setterPerW Float?  /// null = auto (closerPerW + 0.10)
  /// @sensitivity admin — company cost; never expose to non-admin viewers
  kiloPerW   Float

  /// @sensitivity admin — sub-dealer payment rate; admin-only
  /// Sub-dealer rate: what Kilo pays the sub-dealer per watt (null = sub-dealers cannot sell this installer/tier)
  subDealerPerW Float?

  @@index([versionId])
}

// ============================================================================
// PRICING — PRODUCT CATALOG TRACK (SolarTech + future catalog installers)
// ============================================================================

/// Per-installer product catalog configuration.
model ProductCatalogConfig {
  id          String    @id @default(cuid())
  installerId String    @unique
  installer   Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)

  /// Comma-separated family names, e.g. "Goodleap,Enfin,Lightreach,Cash/HDM/PE"
  families          String @default("")
  /// JSON: {"Goodleap":"Goodleap","Enfin":"Enfin",...}
  familyFinancerMap String @default("{}")
  /// Which family is prepaid (e.g. "Cash/HDM/PE")
  prepaidFamily     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A named product within an installer's catalog.
model Product {
  id          String    @id @default(cuid())
  installerId String
  installer   Installer @relation(fields: [installerId], references: [id], onDelete: Cascade)
  family      String
  name        String
  active      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pricingVersions ProductPricingVersion[]
  projects        Project[]               @relation("ProjectProduct")

  @@index([installerId, family])
  @@index([installerId, active])
}

/// Versioned pricing for a specific product. effectiveTo=null = currently active.
model ProductPricingVersion {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label         String
  effectiveFrom String   /// ISO date YYYY-MM-DD
  effectiveTo   String?  /// null = currently active

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tiers    ProductPricingTier[]
  projects Project[]            @relation("ProjectProductPricingVersion")

  @@index([productId, effectiveFrom])
}

/// kW-tier rates within a ProductPricingVersion.
model ProductPricingTier {
  id         String                @id @default(cuid())
  versionId  String
  version    ProductPricingVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  minKW      Float
  maxKW      Float?  /// null = no upper limit
  closerPerW Float
  setterPerW Float   /// explicit (usually closerPerW + 0.10)
  /// @sensitivity admin — company cost; never expose to non-admin viewers
  kiloPerW   Float

  /// @sensitivity admin — sub-dealer payment rate; admin-only
  /// Sub-dealer rate: what Kilo pays the sub-dealer per watt (null = sub-dealers cannot sell this product/tier)
  subDealerPerW Float?

  @@index([versionId])
}

// ============================================================================
// PROJECTS (DEALS)
// ============================================================================

model Project {
  id           String @id @default(cuid())
  customerName String

  closerId String
  closer   User   @relation("ProjectCloser", fields: [closerId], references: [id])
  setterId String?
  setter   User?  @relation("ProjectSetter", fields: [setterId], references: [id])

  /// Sub-dealer who submitted this deal (null for direct Kilo deals)
  subDealerId String?
  subDealer   User?  @relation("ProjectSubDealer", fields: [subDealerId], references: [id])

  soldDate String /// ISO date YYYY-MM-DD

  installerId String
  installer   Installer @relation(fields: [installerId], references: [id])
  financerId  String
  financer    Financer  @relation(fields: [financerId], references: [id])

  /// "PPA" | "Lease" | "Loan" | "Cash"
  productType String

  kWSize Float
  netPPW Float

  /// "New" | "Acceptance" | "Site Survey" | "Design" | "Permitting" |
  /// "Pending Install" | "Installed" | "PTO" | "Completed" | "Cancelled" | "On Hold"
  phase String @default("New")

  m1Paid              Boolean @default(false)
  /// Commission milestone amounts stored as INTEGER CENTS (not dollars).
  /// Compute via lib/money.ts ($.fromCents / $.toDollars) — never mix raw
  /// with dollar amounts. Float→Int cents migration landed 2026-04-15.
  m1AmountCents       Int     @default(0)
  m2Paid              Boolean @default(false)
  m2AmountCents       Int     @default(0)
  m3AmountCents       Int?
  m3Paid              Boolean @default(false)
  setterM1AmountCents Int     @default(0)
  setterM2AmountCents Int     @default(0)
  setterM3AmountCents Int?

  notes              String  @default("")
  // Admin + PM only. Reps / trainers / sub-dealers never receive this
  // field in their /api/data payload (scrubbed by fieldVisibility.ts).
  // Replaces the "glide admin-only notes" concept: private reference
  // notes on a project separate from the rep-visible `notes` field.
  adminNotes         String  @default("")
  flagged            Boolean @default(false)
  cancellationReason String?
  cancellationNotes  String?

  // --- Pricing snapshot references ---
  installerPricingVersionId String?
  installerPricingVersion   InstallerPricingVersion? @relation("ProjectInstallerPricingVersion", fields: [installerPricingVersionId], references: [id])

  productId               String?
  product                 Product?              @relation("ProjectProduct", fields: [productId], references: [id])

  productPricingVersionId String?
  productPricingVersion   ProductPricingVersion? @relation("ProjectProductPricingVersion", fields: [productPricingVersionId], references: [id])

  /// JSON override: {"closerPerW":X,"kiloPerW":Y,"setterPerW":Z}
  baselineOverrideJson String?

  prepaidSubType String?

  // --- Blitz attribution ---
  /// "organic" | "referral" | "blitz" | "door_knock" | "web" | "other"
  leadSource String?
  blitzId    String?
  blitz      Blitz?  @relation(fields: [blitzId], references: [id])

  // --- Per-project trainer override ---
  // One-off trainer attachment for deals where the TrainerAssignment chain
  // doesn't apply (e.g., historical Glide imports, trainers who came in for
  // a single deal). When set, the commission calculator uses these instead
  // of the rep's tiered TrainerAssignment. When null, normal tier chain runs.
  trainerId   String?
  trainer     User?   @relation("ProjectTrainer", fields: [trainerId], references: [id])
  /// Override rate in $/W. Paired with trainerId. Admin-set in project sheet.
  trainerRate Float?

  /// Admin's explicit "remove all trainers from this deal" flag. Set true by
  /// the project sheet's Clear button. When true: chain-trainee visibility AND
  /// chain-trainee commission are suppressed for this project. The trainee's
  /// chain trainer no longer sees the project in their list and no longer
  /// earns M2/M3 override on it. Default false preserves current behavior —
  /// new projects auto-attach the closer's chain trainer as today.
  noChainTrainer Boolean @default(false)

  /// Set only when phase changes — used by Needs Attention staleness calc.
  /// Null for projects created before this field was added.
  phaseChangedAt DateTime?

  // --- BVI / per-installer handoff ---
  /// Per-installer intake fields. Shape varies per installer — typed in
  /// lib/installer-intakes/<slug>.ts. Stored as JSON so adding a new
  /// installer's intake is a code change (template + types) without a
  /// schema migration. Vendor-PM-of-OTHER-installer must never see this
  /// (scrubbed at the serializer); BVI's vendor PM sees their own.
  installerIntakeJson String?
  /// Stamped on first successful handoff send. Drives the 60s replay
  /// guard and the "Sent" badge on the project page.
  handoffSentAt DateTime?
  /// Stamped on every "Resend to Installer" override after the initial send.
  handoffLastResendAt DateTime?
  /// FK convenience — points at the ProjectFile holding the homeowner's
  /// utility bill. Null = no bill on file. Cascades managed at app layer
  /// (ProjectFile is the canonical source; this is a lookup shortcut).
  utilityBillFileId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrollEntries PayrollEntry[]
  activities     ProjectActivity[]
  messages       ProjectMessage[]
  projectNotes   ProjectNote[]
  adminNotesList ProjectAdminNote[]
  // BVI handoff relations
  files            ProjectFile[]
  surveyLinks      ProjectSurveyLink[]
  installerNotes   ProjectInstallerNote[]
  emailDeliveries  EmailDelivery[]
  notificationDeliveries NotificationDelivery[]

  /// Tag-team support: extra closers / setters on a deal beyond the primary.
  /// Empty for a standard single-closer, single-setter deal — no query cost.
  additionalClosers ProjectCloser[]
  additionalSetters ProjectSetter[]

  /// True when this project was bulk-imported from Glide (the 2026-04-16
  /// migration). Chargeback generation skips these — the imported rows
  /// carry their own historical reconciliation, and re-generating would
  /// double-charge reps. Set by scripts/backfill-imported-from-glide.mjs
  /// for existing rows; remains false for all net-new deals.
  importedFromGlide Boolean @default(false)

  @@index([closerId])
  @@index([setterId])
  @@index([subDealerId])
  @@index([installerId])
  @@index([trainerId])
  @@index([phase])
  @@index([soldDate])
  @@index([blitzId])
}

// ============================================================================
// PROJECT CO-CLOSERS / CO-SETTERS
// ============================================================================
// Tag-team support. The primary closer stays on Project.closerId (and
// primary setter on Project.setterId). These join tables hold every
// ADDITIONAL person who co-closed / co-set a deal along with their own
// per-milestone commission cut. A standard single-closer, single-setter
// deal has zero rows in these tables — the existing code path is unchanged.

model ProjectCloser {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("ProjectAdditionalClosers", fields: [userId], references: [id])

  /// This person's personal cut per milestone, stored as integer cents.
  /// Matches the Project.m1AmountCents storage convention set by the
  /// 2026-04-15 Float→Int money migration.
  m1AmountCents Int  @default(0)
  m2AmountCents Int  @default(0)
  m3AmountCents Int?

  /// Display order among additional closers. Position 1 = first co-closer.
  position  Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model ProjectSetter {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation("ProjectAdditionalSetters", fields: [userId], references: [id])

  m1AmountCents Int  @default(0)
  m2AmountCents Int  @default(0)
  m3AmountCents Int?

  position  Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// ============================================================================
// PROJECT ACTIVITY (audit trail)
// ============================================================================

model ProjectActivity {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 'phase_change' | 'flagged' | 'unflagged' | 'm1_paid' | 'm2_paid' | 'note_edit' | 'field_edit' | 'created' | 'setter_assigned'
  type      String
  /// Human-readable description: "Phase changed from Design to Permitting"
  detail    String
  /// Optional JSON metadata (old/new values)
  meta      String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

// ============================================================================
// PAYROLL
// ============================================================================

model PayrollEntry {
  id        String  @id @default(cuid())
  repId     String
  rep       User    @relation(fields: [repId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  /// Integer cents. See Project.m1AmountCents for the rationale.
  amountCents Int

  /// "Deal" | "Bonus"
  type String

  /// "M1" | "M2" | "M3" | "Bonus"
  paymentStage String

  /// "Draft" | "Pending" | "Paid"
  status String @default("Draft")

  /// Timestamp of the Draft→Paid or Pending→Paid transition. Used by the
  /// grace-window rule in PATCH /api/payroll/[id]: Paid→Pending reversal
  /// is allowed only if paidAt is within the last 24 hours. Null until
  /// the entry is first marked Paid.
  paidAt DateTime?

  date  String /// ISO date YYYY-MM-DD
  notes String @default("")

  /// Optional idempotency key — when present, repeated POSTs with the same key
  /// return the existing row instead of inserting a duplicate. Prevents
  /// accidental double-pay from double-clicks or network retries.
  idempotencyKey String? @unique

  /// Chargeback tracking — explicit flag + link to the original Paid entry
  /// being clawed back. Amount on a chargeback entry is always negative
  /// (sum-aggregators rely on that). Keeping these fields explicit avoids
  /// conflating chargebacks with refunds, adjustments, or other negative
  /// entries that will accumulate over time. See lib/chargebacks.md.
  isChargeback   Boolean @default(false)
  chargebackOfId String?
  chargebackOf   PayrollEntry?  @relation("ChargebackLink", fields: [chargebackOfId], references: [id])
  chargebacks    PayrollEntry[] @relation("ChargebackLink")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([repId])
  @@index([projectId])
  @@index([status])
  @@index([date])
  @@index([isChargeback])
  @@index([chargebackOfId])
}

// ============================================================================
// REIMBURSEMENTS
// ============================================================================

model Reimbursement {
  id          String @id @default(cuid())
  repId       String
  rep         User   @relation(fields: [repId], references: [id])
  /// Integer cents. See Project.m1AmountCents for the rationale.
  amountCents Int
  description String
  date        String /// ISO date YYYY-MM-DD

  /// "Pending" | "Approved" | "Denied" | "Rejected"
  status String @default("Pending")

  /// Original filename as uploaded by the rep (display only).
  receiptName String?
  /// Vercel Blob public URL where the receipt file lives. Null if no
  /// receipt was uploaded; if the blob is deleted the URL stays as a
  /// breadcrumb but may 404 on fetch.
  receiptUrl  String?

  /// Soft-archive timestamp. Non-null = hidden from the default list but
  /// recoverable. Separate from status so "Archived Approved" and
  /// "Archived Denied" are distinguishable during audit.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([repId])
  @@index([status])
  @@index([archivedAt])
}

// ============================================================================
// TRAINER SYSTEM
// ============================================================================

model TrainerAssignment {
  id        String  @id @default(cuid())
  trainerId String
  trainer   User    @relation("Trainer", fields: [trainerId], references: [id])
  traineeId String
  trainee   User    @relation("Trainee", fields: [traineeId], references: [id])
  active    Boolean @default(true)

  /// Training vs. residuals. true = actively coaching (trainer sees trainee's
  /// project list + coaching UI). false = Residuals — override still earns on
  /// trainee's deals but trainer no longer coaches; trainee profile hides the
  /// trainer card. Flipped by admin/trainer via "Mark as Graduated" action.
  isActiveTraining Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tiers TrainerOverrideTier[]

  @@unique([trainerId, traineeId])
  @@index([trainerId])
  @@index([traineeId])
}

model TrainerOverrideTier {
  id           String            @id @default(cuid())
  assignmentId String
  assignment   TrainerAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  /// Deal count threshold. null = perpetual.
  upToDeal  Int?
  /// Override rate in $/W
  ratePerW  Float
  /// Sort order (0-indexed)
  sortOrder Int @default(0)

  @@index([assignmentId])
}

// ============================================================================
// INCENTIVES
// ============================================================================

model Incentive {
  id          String  @id @default(cuid())
  title       String
  description String  @default("")

  /// "company" | "personal"
  type   String
  /// "deals" | "kw" | "commission" | "revenue"
  metric String
  /// "month" | "quarter" | "year" | "alltime"
  period String

  startDate String  /// ISO date YYYY-MM-DD
  endDate   String? /// ISO date YYYY-MM-DD

  /// null = company-wide
  targetRepId String?
  targetRep   User?  @relation(fields: [targetRepId], references: [id])

  active Boolean @default(true)

  /// Optional: scope incentive to a specific blitz
  blitzId String?
  blitz   Blitz?  @relation(fields: [blitzId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  milestones IncentiveMilestone[]

  @@index([active])
  @@index([targetRepId])
  @@index([blitzId])
}

model IncentiveMilestone {
  id          String    @id @default(cuid())
  incentiveId String
  incentive   Incentive @relation(fields: [incentiveId], references: [id], onDelete: Cascade)
  threshold   Float
  reward      String
  achieved    Boolean   @default(false)

  @@index([incentiveId])
}

// ============================================================================
// BLITZ MODULE
// ============================================================================

model Blitz {
  id        String @id @default(cuid())
  name      String
  location  String @default("")
  housing   String @default("")
  startDate String /// ISO date YYYY-MM-DD
  endDate   String /// ISO date YYYY-MM-DD
  notes     String @default("")

  /// "upcoming" | "active" | "completed" | "cancelled"
  status String @default("upcoming")

  createdById String
  createdBy   User   @relation("BlitzCreator", fields: [createdById], references: [id])
  ownerId     String
  owner       User   @relation("BlitzOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants         BlitzParticipant[]
  costs                BlitzCost[]
  incentives           Incentive[]
  projects             Project[]
  cancellationRequests BlitzRequest[]

  @@index([status])
  @@index([ownerId])
  @@index([startDate])
}

model BlitzParticipant {
  id      String @id @default(cuid())
  blitzId String
  blitz   Blitz  @relation(fields: [blitzId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  /// "pending" | "approved" | "declined"
  joinStatus       String  @default("pending")
  /// "attended" | "no_show" | "partial" — null until recorded
  attendanceStatus String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([blitzId, userId])
  @@index([blitzId])
  @@index([userId])
}

model BlitzCost {
  id      String @id @default(cuid())
  blitzId String
  blitz   Blitz  @relation(fields: [blitzId], references: [id], onDelete: Cascade)

  /// "housing" | "travel" | "gas" | "meals" | "incentives" | "swag" | "other"
  category    String
  /// Integer cents. See Project.m1AmountCents for the rationale.
  amountCents Int
  description String @default("")
  date        String /// ISO date YYYY-MM-DD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blitzId])
}

// ============================================================================
// PROJECT CHATTER
// ============================================================================

model ProjectMessage {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String   // rep or admin user ID
  authorName String
  authorRole String   // 'admin', 'rep', 'sub-dealer'
  text       String
  createdAt  DateTime @default(now())

  checkItems ProjectCheckItem[]
  mentions   ProjectMention[]

  @@index([projectId])
}

model ProjectCheckItem {
  id          String          @id @default(cuid())
  messageId   String
  message     ProjectMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  text        String
  completed   Boolean         @default(false)
  completedBy String?
  completedAt DateTime?
  dueDate     DateTime?

  @@index([messageId])
}

model ProjectMention {
  id        String          @id @default(cuid())
  messageId String
  message   ProjectMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime?

  @@index([messageId])
  @@index([userId])
}

/// Standalone per-project note. Replaces the earlier single-textarea
/// pattern on Project.notes — each row is an individually-deletable
/// entry authored by a specific user at a specific time. Legacy
/// Project.notes content is migrated into these rows on first run
/// of scripts/migrate-add-project-notes-table.mjs.
model ProjectNote {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  text       String
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

/// User-submitted feedback from the in-app "Send feedback" widget.
/// Operational queue, admin-only access. Lands in DB AND emails Josh
/// at jarvisbyjosh@gmail.com so he can triage from his inbox. Privacy:
/// the message text is user-typed content — by submitting, the user
/// consents to sharing with Kilo admin. We do NOT auto-append other
/// project/commission context; only what the user typed plus URL/role
/// metadata they're aware travels. Table is allowlisted for the
/// privacy gate (operational data, no per-rep scoping).
model Feedback {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])

  /// Role at submission time (rep can change roles later — preserve original).
  userRoleSnapshot String

  /// Free-form user-typed text. Length-capped at the API layer (Zod max 2000).
  message          String

  /// Page URL at submission (relative path; no domain). Used for triage context.
  url              String?

  /// Browser/OS string. Optional debug context.
  userAgent        String?

  /// Admin workflow fields (v1 leaves these null; v2 admin UI uses them).
  resolved         Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?
  resolverNote     String?

  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([resolved, createdAt])
  @@index([createdAt])
}

/// Admin-only counterpart of ProjectNote. Never visible to reps,
/// trainers, sub-dealers, or vendor PMs — enforced at the endpoint
/// boundary (admin + internal PM only) AND via the field-visibility
/// scrubber on the legacy Project.adminNotes string. Mirrors the
/// same schema shape so the UI can share a component.
model ProjectAdminNote {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId   String
  authorName String
  text       String
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([authorId])
}

// ============================================================================
// AUDIT LOG
// ============================================================================

/// Immutable record of sensitive mutations (phase changes, financial edits,
/// role/active flips, payroll publishes). Written by lib/audit.ts logChange().
model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

/// Read-side counterpart to AuditLog. Records who hit a sensitive
/// endpoint and which model rows were returned, so a privacy leak
/// can be diagnosed forensically (which user saw what, when, for
/// how long). Distinct from AuditLog because reads are high-volume
/// and one row carries N record IDs as a JSON array.
///
/// Retention: 90 days, enforced by a cleanup script run nightly.
model DataAccessLog {
  id              String   @id @default(cuid())
  /// The authenticated user who made the request.
  actorUserId     String
  /// Optional view-as target — when admin is impersonating, this is
  /// the user whose visibility rules were applied. Null otherwise.
  effectiveUserId String?
  /// Route path, e.g. "/api/data" or "/api/projects/[id]".
  route           String
  /// The model whose rows were exposed, e.g. "Project".
  modelName       String
  /// JSON array of record IDs returned to the caller. Capped to
  /// the first 1000 ids per request — beyond that we just log
  /// the count, since high-cardinality logs are noise.
  recordIdsJson   String
  /// Total number of records returned (== recordIds.length when
  /// uncapped, > recordIds.length when truncated for log size).
  recordCount     Int
  createdAt       DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([modelName, createdAt])
  @@index([createdAt])
}

model BlitzRequest {
  id            String @id @default(cuid())
  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id])

  /// "create" | "cancel" — type of request
  type          String @default("create")

  /// For cancel requests: the blitz being requested for cancellation
  blitzId       String?
  blitz         Blitz?  @relation(fields: [blitzId], references: [id], onDelete: SetNull)

  name              String
  location          String @default("")
  startDate         String /// ISO date YYYY-MM-DD
  endDate           String /// ISO date YYYY-MM-DD
  housing           String @default("")
  notes             String @default("")
  expectedHeadcount Int    @default(0)

  /// "pending" | "approved" | "denied"
  status     String  @default("pending")
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestedById])
  @@index([status])
}

// ============================================================================
// BVI HANDOFF — installer-handoff surfaces
// ============================================================================
// Sensitive models. All four below must be visible to:
//   - admin
//   - internal PM
//   - vendor PM whose scopedInstallerId matches the project's installerId
// Reps, setters, sub-dealers, misconfigured PMs, and unknown roles all DENY.
// See lib/db-gated.ts → installerSurfaceProjectWhere() for the policy.

/// Generic per-installer file storage. Holds utility bills (kind='utility_bill'),
/// permits, plans, inspection reports, as-built photos. Each row references a
/// blob in Vercel Blob (private access mode); reads go through the gated
/// download proxy at /api/projects/[id]/files/[fileId]/download which signs a
/// short-lived URL after role check + audit log. blobUrl is opaque — never
/// expose directly to clients.
model ProjectFile {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 'utility_bill' | 'permit' | 'plan' | 'inspection' | 'as_built' | 'other'
  kind         String
  /// Human-readable label (e.g. "May 2026 utility bill")
  label        String
  /// Original filename as uploaded (display only; do not use for storage path).
  originalName String
  /// Vercel Blob URL — private mode, requires signed URL to fetch.
  blobUrl      String
  /// Blob path/key for delete operations.
  blobPath     String
  mimeType     String
  sizeBytes    Int

  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([kind])
}

/// External links (Google Drive folders, Dropbox, OneDrive) where installer
/// PMs upload site-survey photos / supporting docs. We do not host the
/// content; we just track the link, label, and provenance. URL validation
/// at the route layer rejects non-HTTPS URLs.
model ProjectSurveyLink {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url         String
  label       String

  addedById   String
  addedBy     User     @relation(fields: [addedById], references: [id])

  createdAt   DateTime @default(now())

  @@index([projectId])
}

/// Per-project notes scoped to the installer-handoff audience (admin +
/// internal PM + vendor PM of matching installer). Distinct from
/// ProjectNote (rep-visible) and ProjectAdminNote (admin-only). This is
/// where BVI's vendor PM leaves "scheduled site survey for Tuesday"-type
/// status updates that the rep doesn't need to see.
model ProjectInstallerNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  body      String

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([authorId])
}

/// Per-send delivery status record. One row per /api/projects/[id]/handoff
/// POST (whether real or test=true). Updated by the Resend webhook receiver
/// at /api/webhooks/resend with delivered/bounced/complained transitions.
/// Surfaces on project page as the HandoffStatusCard; bounces feed the
/// daily stalled digest's "bounced handoffs" section.
model EmailDelivery {
  id                String    @id @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Optional — null when send is not installer-keyed (e.g. internal test send).
  installerId       String?
  installer         Installer? @relation(fields: [installerId], references: [id])

  /// Resend API message id; webhook events match against this.
  providerMessageId String?   @unique

  /// JSON-encoded String[] of recipient envelope addresses.
  toEmails          String
  ccEmails          String

  subject           String

  /// 'queued' | 'sent' | 'delivered' | 'bounced' | 'complained' | 'failed'
  status            String

  /// Bounce/complaint detail when status is bounced/complained/failed.
  errorReason       String?

  sentAt            DateTime  @default(now())
  deliveredAt       DateTime?
  bouncedAt         DateTime?

  /// True when the send was triggered with ?test=true (admin self-test).
  /// Test sends do NOT count toward Project.handoffSentAt or idempotency.
  isTest            Boolean   @default(false)

  createdById       String
  createdBy         User      @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([providerMessageId])
}

// ============================================================================
// STALLED PROJECT ALERT CONFIG (admin singleton)
// ============================================================================

/// Admin-managed config powering the daily stalled-project digest.
/// Single-row by convention (id = "singleton"). Read by the cron at
/// /api/cron/stalled-digest. Edited via /api/admin/stalled-config.
/// Not in the privacy gate (admin-only endpoint by route guard);
/// allowlisted in scripts/privacy-gate-coverage.allowlist.json.
model StalledAlertConfig {
  id                  String   @id @default("singleton")

  /// Master kill switch. False = no digest sent regardless of cron firing.
  enabled             Boolean  @default(true)

  /// Projects whose soldDate is older than this many days are exempt
  /// from the digest regardless of phase or threshold (legacy-data filter).
  soldDateCutoffDays  Int      @default(180)

  /// JSON-encoded String[] of email addresses to receive the daily digest.
  digestRecipients    String   @default("[]")

  /// JSON-encoded { phaseName: thresholdDays }. Phases not present
  /// fall back to DEFAULT_THRESHOLDS in the cron handler.
  phaseThresholds     String   @default("{}")

  /// Hour-of-day (0-23 UTC) when the digest is expected to fire. Used
  /// by the cron route to short-circuit if invoked off-schedule.
  /// Default 15 = 8am Pacific Time.
  digestSendHourUtc   Int      @default(15)

  updatedAt           DateTime @updatedAt
  updatedById         String?
}

// ============================================================================
// NOTIFICATION SYSTEM
// ============================================================================
// Per-user opt-in/opt-out for each notification event type, plus a
// generalized delivery log (replaces EmailDelivery as the long-term home;
// EmailDelivery stays for back-compat during the migration window).
//
// The NotificationService facade in lib/notifications/service.ts is the
// only writer to NotificationDelivery; route handlers fire `notify(...)`
// events and the service handles preference lookup, channel fan-out,
// and per-channel adapter dispatch (Resend / Twilio / Web Push).
//
// Privacy gate: Notification* models are user-scoped. The privacy gate
// allowlist treats them as "owner-self only" — a user only ever sees
// their own preferences and deliveries (admin override via dedicated
// admin route, audited).

/// One row per (user, eventType). Missing row = use the event-type's
/// default policy from lib/notifications/events.ts.
model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Identifier from the event-type registry (lib/notifications/events.ts).
  /// Examples: 'mention', 'project_phase_change', 'pay_pending', 'pay_paid',
  /// 'milestone_install_scheduled', 'handoff_bounced', 'admin_user_invited'.
  eventType   String

  /// Channel toggles. Independent — opt in to email but not SMS, etc.
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)
  pushEnabled  Boolean @default(false)

  /// 'instant' | 'daily_digest' | 'weekly_digest' | 'off'.
  /// 'off' is a master kill switch — overrides individual channel toggles.
  digestMode  String   @default("instant")

  updatedAt   DateTime @updatedAt

  @@unique([userId, eventType])
  @@index([userId])
}

/// Generalized delivery log. Every notify() call produces one row per
/// channel attempt; provider webhooks update status/timestamps.
model NotificationDelivery {
  id        String   @id @default(cuid())

  /// Recipient user. Null for system-only emails (e.g. legacy stalled
  /// digest to a configured admin list — those addresses are ad-hoc).
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// Event type — vocabulary aligned with NotificationPreference.eventType.
  eventType String

  /// 'email' | 'sms' | 'push' | 'in_app'. Adapter-coupled dispatch key.
  channel   String

  /// Recipient address — email, E.164 phone, or push subscription endpoint.
  toAddress String

  /// Provider-side message id (Resend/Twilio/Web Push) for webhook joins.
  providerMessageId String? @unique

  /// 'queued' | 'sent' | 'delivered' | 'bounced' | 'complained' | 'failed'.
  status    String

  /// Webhook reason on bounce/complaint/failure — surfaced to admin in the
  /// notification audit view.
  errorReason String?

  /// JSON-encoded payload for forensics + future replay capability.
  /// Keep small — large bodies belong in entity-specific tables, not here.
  payloadJson String?

  /// Optional project context. Drives the privacy-gate exposure — a user
  /// can only see their own deliveries OR deliveries on a project they
  /// can access (via userCanAccessProject).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  sentAt    DateTime  @default(now())
  deliveredAt DateTime?
  bouncedAt   DateTime?

  @@index([userId])
  @@index([projectId])
  @@index([providerMessageId])
  @@index([eventType, sentAt])
}

/// Web Push / native push token registry. One row per (user, device).
/// Web Push (today, VAPID-signed) populates endpoint+p256dh+auth.
/// Native (post-app-store, APNs/FCM) populates nativeToken instead.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 'web_push' (today) | 'apns' (iOS native, post-app-store)
  /// | 'fcm' (Android native, post-app-store).
  provider  String   @default("web_push")

  /// Web Push API endpoint URL. Unique per device-browser pair —
  /// re-subscribing with the same endpoint is idempotent (upsert by endpoint).
  /// For native push, this stores the platform-specific endpoint URL or
  /// is left empty and nativeToken is populated instead.
  endpoint  String   @unique

  /// Web Push key material (split to avoid stringly-typed JSON blob).
  p256dh    String?
  auth      String?

  /// Native push token (APNs device token / FCM registration token).
  /// Populated only for provider='apns'|'fcm'; null for web_push.
  nativeToken String?

  userAgent String?

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}
