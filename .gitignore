# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
/dev.db
/dev.db-journal
/prisma/dev.db
/prisma/dev.db-journal

# claude code local settings
.claude/settings.local.json

.vercel

# Playwright browser cache (created when running e2e tests with persistent
# context). Hundreds of binary files that should never be in git — they
# polluted git status for months before being cleaned up.
.playwright-session/

# Generated visual artifacts from manual + automated screenshot runs.
qa-screenshots/
screenshots/
mobile-audit-screenshots/
