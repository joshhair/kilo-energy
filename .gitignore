# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma
/dev.db
/dev.db-journal
/prisma/dev.db
/prisma/dev.db-journal

# claude code local settings
.claude/settings.local.json

.vercel

# Playwright browser cache (created when running e2e tests with persistent
# context). Hundreds of binary files that should never be in git — they
# polluted git status for months before being cleaned up.
.playwright-session/

# Generated visual artifacts from manual + automated screenshot runs.
qa-screenshots/
screenshots/
mobile-audit-screenshots/

# Turso backups: ignore routine dumps but keep any explicit anchor
# snapshots that have been committed as point-in-time safety nets.
# Anchor dumps live at state/backups/anchor-*.json — the * prefix is
# negated below so they're checked in.
state/backups/*.json
!state/backups/anchor-*.json

# Playwright authenticated storage states. These contain Clerk session
# cookies for the E2E test users — rotating them is cheap, but checking
# them into git is a credential leak. Regenerate via `npm run test:e2e`
# (the setup project runs the sign-in flow and writes these files).
tests/e2e/.auth/

# Local ad-hoc debug scripts — keep the content but don't let them
# break typecheck / lint / CI. If a script is worth keeping long-
# term, move it out of .local/ and rename to something descriptive.
scripts/.local/
scripts/*.mts.bak
scripts/*.mts.local

# scripts/find-timothy.mts — orphan from an early debugging session,
# references sqlite3/sqlite modules that aren't in package.json.
# Breaks typecheck every time it's present. Content is preserved
# as a .bak when any ci-sensitive script runs. Not worth keeping
# in the tree under its real name.
scripts/find-timothy.mts

# Glide migration debug scripts + review reports (contain customer PII).
# Kept on disk untracked so Josh can re-run them; never shipped.
state/glide-*.txt
state/glide-*.html
state/glide-*.json
scripts/analyze-glide-*.mts
scripts/glide-review-report.mts
scripts/debug-glide-*.mts
scripts/debug-installer-columns.mts
scripts/debug-max-deal.mts
scripts/debug-unresponsive.mts
scripts/check-gary-leger.mts
scripts/check-hunter.mts
scripts/check-prod-counts.mts
scripts/check-role-counts.mts
scripts/check-site-survey.mts
